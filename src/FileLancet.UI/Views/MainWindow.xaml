<Window x:Class="FileLancet.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FileLancet.UI.ViewModels"
        Title="File Lancet - EPUB Analyzer" 
        Height="800" 
        Width="1400"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" IsMainMenu="True">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="E_xport..." Command="{Binding ExportCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Height="35">
            <Button Content="Open" Command="{Binding OpenFileCommand}" Padding="10,2"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="10,2" Margin="5,0,0,0"/>
            <Separator Margin="10,0"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="10,0"/>
        </ToolBar>

        <!-- Main Content - Three Column Layout -->
        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="400" MinWidth="250" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: File Tree -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="File Structure" FontWeight="Bold" Padding="5" Background="LightGray"/>
                    
                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding FileTreeNodes}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              Margin="2">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Margin="2,0"/>
                                    <TextBlock Text="{Binding Type, StringFormat=' ({0})'}" 
                                               Foreground="Gray" 
                                               FontSize="10"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- Middle Column: Details -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Details" FontWeight="Bold" Padding="5" Background="LightGray"/>
                    
                    <!-- Basic Info -->
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NodeDetails.NodeName}" Margin="2"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.NodeType}" Margin="2"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Size:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.FileSize}" Margin="2"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Path:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.NodePath}" Margin="2" TextWrapping="Wrap"/>
                    </Grid>
                    
                    <!-- EPUB Metadata -->
                    <Grid Grid.Row="2" Margin="5" Visibility="{Binding NodeDetails.IsEpubMetadataVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="EPUB Metadata" FontWeight="Bold" FontSize="14" Margin="0,10,0,5" Foreground="DarkBlue"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Title:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.Title}" Margin="2"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Authors:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.Authors}" Margin="2"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Publisher:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.Publisher}" Margin="2"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Language:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeDetails.Language}" Margin="2"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Version:" FontWeight="Bold" Margin="2"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding NodeDetails.EpubVersion}" Margin="2"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- Right Column: Preview -->
            <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{Binding Preview.PreviewTitle}" FontWeight="Bold" Padding="5" Background="LightGray"/>
                    
                    <!-- Text Preview -->
                    <TextBox Grid.Row="1" 
                             Text="{Binding Preview.TextContent}" 
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=Text}"/>
                    
                    <!-- Image Preview -->
                    <Image Grid.Row="1" 
                           Source="{Binding Preview.ImageContent}" 
                           Stretch="Uniform"
                           Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=Image}"/>
                    
                    <!-- Binary Preview -->
                    <TextBlock Grid.Row="1" 
                               Text="{Binding Preview.BinaryInfo}" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=Binary}"/>
                    
                    <!-- Empty/None Preview -->
                    <TextBlock Grid.Row="1" 
                               Text="Select a file to preview"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=None}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="|"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" MaxWidth="800"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
