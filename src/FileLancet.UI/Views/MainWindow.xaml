<Window x:Class="FileLancet.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FileLancet.UI.ViewModels"
        xmlns:converters="clr-namespace:FileLancet.UI.Converters"
        Title="File Lancet - File Analyzer" 
        Height="800" 
        Width="1400"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Height="35">
            <Button Content="Open" Command="{Binding OpenFileCommand}" Padding="15,5"/>
            <Button Content="About" Click="AboutMenuItem_Click" Padding="15,5" Margin="5,0,0,0"/>
        </ToolBar>

        <!-- Main Content - Left Panel (Tree + Details) and Right Panel (Preview) -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="250" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: File Tree + Details (Stacked vertically) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="250" MinHeight="150" MaxHeight="400"/>
                </Grid.RowDefinitions>

                <!-- Top: File Tree -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Margin="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="File Structure" FontWeight="Bold" Padding="5" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                        
                        <TreeView Grid.Row="1" 
                                  ItemsSource="{Binding FileTreeNodes}"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  Margin="2">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Margin="2,0"/>
                                        <TextBlock Text="{Binding Type, StringFormat=' ({0})'}" 
                                                   Foreground="Gray" 
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- Splitter between Tree and Details -->
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" 
                              Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                              ShowsPreview="False"/>

                <!-- Bottom: Details Panel -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Margin="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Details" FontWeight="Bold" Padding="5" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                        
                        <!-- Basic Info -->
                        <Grid Grid.Row="1" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NodeDetails.NodeName}" Margin="2"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.NodeType}" Margin="2"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Extension:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.FileExtension}" Margin="2"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="MIME:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.MimeType}" Margin="2"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Size:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeDetails.FileSize}" Margin="2"/>
                            
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Modified:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding NodeDetails.LastModified}" Margin="2"/>
                            
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Path:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding NodeDetails.NodePath}" Margin="2" TextWrapping="Wrap"/>
                        </Grid>
                        
                        <!-- EPUB Metadata -->
                        <Grid Grid.Row="2" Margin="5" Visibility="{Binding NodeDetails.IsEpubMetadataVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="EPUB Metadata" FontWeight="Bold" FontSize="14" Margin="0,10,0,5" Foreground="DarkBlue"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Title:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.Title}" Margin="2"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Authors:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.Authors}" Margin="2"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Publisher:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.Publisher}" Margin="2"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Language:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeDetails.Language}" Margin="2"/>
                            
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Version:" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding NodeDetails.EpubVersion}" Margin="2"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter between Left and Right -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" 
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                          ShowsPreview="False"/>

            <!-- Right Column: Preview (Wider) -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Margin="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{Binding Preview.PreviewTitle}" FontWeight="Bold" Padding="5" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                    
                    <!-- Text Preview (for plain text only) -->
                    <TextBox Grid.Row="1" 
                             Text="{Binding Preview.TextContent}" 
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Visibility="{Binding Preview.ShowStructuredView, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    
                    <!-- Structured Code Preview (TreeView) -->
                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding Preview.StructuredContent.Children}"
                              Visibility="{Binding Preview.ShowStructuredView, Converter={StaticResource BooleanToVisibilityConverter}}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayText}" 
                                                   FontFamily="Consolas"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="Element">
                                                            <Setter Property="Foreground" Value="Blue"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="Text">
                                                            <Setter Property="Foreground" Value="DarkGreen"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="Comment">
                                                            <Setter Property="Foreground" Value="Gray"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="CssRule">
                                                            <Setter Property="Foreground" Value="DarkBlue"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="CssProperty">
                                                            <Setter Property="Foreground" Value="DarkCyan"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    
                    <!-- Image Preview -->
                    <Image Grid.Row="1" 
                           Source="{Binding Preview.ImageContent}" 
                           Stretch="Uniform"
                           Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=Image}"/>
                    
                    <!-- Hex Preview (for binary files) -->
                    <TextBox Grid.Row="1" 
                             Text="{Binding Preview.HexContent}" 
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="12"
                             Visibility="{Binding Preview.ShowHexView, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Empty/None Preview -->
                    <TextBlock Grid.Row="1" 
                               Text="Select a file to preview"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               Visibility="{Binding Preview.PreviewType, Converter={StaticResource PreviewTypeToVisibilityConverter}, ConverterParameter=None}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="|"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" MaxWidth="800"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
