<UserControl x:Class="FileLancet.UI.Views.PdfPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Background="#F0F0F0" Padding="5">
            <ToolBar.Resources>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="MinWidth" Value="40"/>
                </Style>
                <Style TargetType="ToggleButton">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </ToolBar.Resources>
            
            <!-- 分页导航 -->
            <Button Content="|◀" Command="{Binding FirstPageCommand}" ToolTip="首页"/>
            <Button Content="◀" Command="{Binding PreviousPageCommand}" ToolTip="上一页"/>
            <TextBlock VerticalAlignment="Center" Margin="10,0">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text="/"/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>
            <Button Content="▶" Command="{Binding NextPageCommand}" ToolTip="下一页"/>
            <Button Content="▶|" Command="{Binding LastPageCommand}" ToolTip="末页"/>
            
            <Separator Margin="10,0"/>
            
            <!-- 缩放控制 -->
            <Button Content="-" Command="{Binding ZoomOutCommand}" ToolTip="缩小"/>
            <TextBlock VerticalAlignment="Center" Margin="5,0" MinWidth="50" TextAlignment="Center">
                <Run Text="{Binding ZoomLevel, StringFormat='{}{0:P0}'}"/>
            </TextBlock>
            <Button Content="+" Command="{Binding ZoomInCommand}" ToolTip="放大"/>
            
            <Separator Margin="10,0"/>
            
            <!-- 适应模式 -->
            <Button Content="适应宽度" Command="{Binding FitWidthCommand}" ToolTip="适应宽度"/>
            <Button Content="适应高度" Command="{Binding FitHeightCommand}" ToolTip="适应高度"/>
            <Button Content="实际大小" Command="{Binding ActualSizeCommand}" ToolTip="实际大小"/>
            
            <Separator Margin="10,0"/>
            
            <!-- 文本模式切换 -->
            <ToggleButton Content="文本模式" IsChecked="{Binding ShowTextMode}" ToolTip="切换文本/图像模式"/>
        </ToolBar>
        
        <!-- 预览区域 -->
        <Border Grid.Row="1" Background="#E0E0E0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- 图像预览 -->
                    <Image Source="{Binding PageImage}" 
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding ShowTextMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    
                    <!-- 文本预览 -->
                    <TextBox Text="{Binding TextContent}" 
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Padding="20"
                             BorderThickness="0"
                             Background="White"
                             Visibility="{Binding ShowTextMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
        </Border>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Padding="10,2"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Padding="10,2">
                    <Run Text="页面尺寸: "/>
                    <Run Text="{Binding PageWidth, StringFormat='{}{0:F0}'}"/>
                    <Run Text=" x "/>
                    <Run Text="{Binding PageHeight, StringFormat='{}{0:F0}'}"/>
                    <Run Text=" pts"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
