<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileLancet.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="FileLancet.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="File Lancet - EPUB 文件分析工具"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- 菜单栏 -->
    <Menu Grid.Row="0">
      <MenuItem Header="文件">
        <MenuItem Header="打开..." Command="{Binding OpenFileCommand}" />
        <Separator />
        <MenuItem Header="退出" />
      </MenuItem>
      <MenuItem Header="帮助">
        <MenuItem Header="关于" />
      </MenuItem>
    </Menu>

    <!-- 主内容区 -->
    <Grid Grid.Row="1" ColumnDefinitions="250,5,*,5,400">
      <!-- 左栏：文件树 -->
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" 
                     Text="文件结构" 
                     FontWeight="Bold" 
                     Margin="10,5"
                     HorizontalAlignment="Center"/>
          <TreeView Grid.Row="1" 
                    ItemsSource="{Binding FileTreeNodes}"
                    SelectedItem="{Binding SelectedNode}"
                    Margin="5">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="{Binding Name}" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <!-- 分隔条1 -->
      <GridSplitter Grid.Column="1" 
                    Background="Gray" 
                    Width="5" 
                    HorizontalAlignment="Stretch"/>

      <!-- 中栏：详情 -->
      <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" 
                     Text="属性详情" 
                     FontWeight="Bold" 
                     Margin="10,5"
                     HorizontalAlignment="Center"/>
          <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel Spacing="10">
              <TextBlock Text="文件信息" FontWeight="Bold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="名称: " Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NodeDetails.Name}" Margin="0,2"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="路径: " Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.Path}" TextWrapping="Wrap" Margin="0,2"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="大小: " Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.Size}" Margin="0,2"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="MIME类型: " Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.MimeType}" Margin="0,2"/>
              </Grid>

              <Separator/>
              
              <TextBlock Text="书籍元数据" FontWeight="Bold" FontSize="16" 
                         IsVisible="{Binding NodeDetails.Metadata, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    IsVisible="{Binding NodeDetails.Metadata, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="标题: " Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NodeDetails.Metadata.Title}" Margin="0,2"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="作者: " Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NodeDetails.Metadata.Author}" Margin="0,2"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="版本: " Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NodeDetails.Metadata.EpubVersion}" Margin="0,2"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="语言: " Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NodeDetails.Metadata.Language}" Margin="0,2"/>
                
                <TextBlock Grid.Row="4" Grid.Column="0" Text="出版社: " Margin="0,2"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeDetails.Metadata.Publisher}" Margin="0,2"/>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- 分隔条2 -->
      <GridSplitter Grid.Column="3" 
                    Background="Gray" 
                    Width="5" 
                    HorizontalAlignment="Stretch"/>

      <!-- 右栏：预览 -->
      <Border Grid.Column="4">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" 
                     Text="内容预览" 
                     FontWeight="Bold" 
                     Margin="10,5"
                     HorizontalAlignment="Center"/>
          <Border Grid.Row="1" 
                  Background="#f0f0f0" 
                  Margin="10"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <TextBlock Text="预览功能开发中..." 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray"/>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- 状态栏 -->
    <Border Grid.Row="2" 
            BorderBrush="Gray" 
            BorderThickness="0,1,0,0" 
            Background="#f5f5f5">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" 
                   Text="{Binding StatusMessage}" 
                   Margin="10,5"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" 
                   Text="{Binding CurrentFilePath}" 
                   Margin="10,5"
                   VerticalAlignment="Center"
                   Foreground="Gray"/>
      </Grid>
    </Border>
  </Grid>
</Window>
